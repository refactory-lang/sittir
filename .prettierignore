# Generated files that use JSON.stringify format (quoted keys).
# oxfmt reformats these to JSON5 (unquoted keys), which breaks
# the validator's JSON.parse-based factory-map loader.
node_modules/
dist/
build/
coverage/
pnpm-lock.yaml

**/factory-map.json5

# factory-map.json5's successor (PR-K consolidation) — same reasoning,
# same JSON.stringify-format concern. Regenerated by codegen; formatting
# it here just gets overwritten on the next regen.
**/node-model.json5

# Volatile generated artifacts (codegen-owned, exclude from format scope)
# These are regenerated frequently and should not be part of default
# format/lint coverage. Stability is achieved at the emitter level.
**/tests/nodes.test.ts
**/*.sittir/**
specs/*/baselines/**
specs/*/perf-baselines/**
specs/*/perf/**

# napi-rs native binding build output (rebuilt via `napi build`, not
# hand-written or codegen-emitted TS/JS in the usual sense).
rust/crates/sittir-*/index.d.ts
rust/crates/sittir-*/index.js

# Validator-run output — regenerated on every validate:native / test run,
# lands in dedicated chore(validator) commits per generated-manifest.ts's
# isManifestUntracked policy. Not source, formatting it is pointless churn.
rust/crates/sittir-*/test-fixtures.json
packages/*/validation-report.json

# Third-party tool caches (infigraph indexer, graphify analysis) — not
# project source; regenerated by their own tools, not oxfmt's concern.
.infigraph/**
graphify-out/**
