{
  "name": "sittir",
  "version": "0.1.0",
  "private": true,
  "description": "Generate typed IR builders from tree-sitter grammars",
  "type": "module",
  "author": "Pradeep Mouli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sittir/sittir.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean && rm -rf node_modules/.cache",
    "clean:all": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules",
    "dev": "pnpm -r --parallel run dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "fresh": "pnpm clean:all && pnpm install",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "type-check": "pnpm -r run type-check",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "docs": "typedoc",
    "docs:md": "typedoc --plugin typedoc-plugin-markdown"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "@vitest/coverage-v8": "^4.1.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tree-sitter-cli": "^0.26.8",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-to-skills": "^0.6.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "web-tree-sitter": "^0.26.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "tree-sitter-cli",
      "tree-sitter-python"
    ]
  }
}
