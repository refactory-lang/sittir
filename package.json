{
  "name": "sittir",
  "version": "0.1.0",
  "private": true,
  "description": "Generate typed IR builders from tree-sitter grammars",
  "license": "MIT",
  "author": "Pradeep Mouli",
  "repository": {
    "type": "git",
    "url": "https://github.com/sittir/sittir.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean && rm -rf node_modules/.cache",
    "clean:all": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules",
    "dev": "pnpm -r --parallel run dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "fresh": "pnpm clean:all && pnpm install",
    "lint": "oxlint -c oxlint.config.ts .",
    "lint:fix": "oxlint -c oxlint.config.ts --fix .",
    "test": "vitest run",
    "validate": "./scripts/run-validate.sh",
    "validate:native": "./scripts/run-validate.sh counts --backend native",
    "probe:validate": "tsx packages/codegen/src/scripts/probe-validate.ts",
    "probe:kind": "tsx packages/codegen/src/scripts/probe-kind.ts",
    "validate:js": "./scripts/run-validate.sh counts --backend js",
    "validate:all": "./scripts/run-validate.sh counts --backend all",
    "validate:probe-factory:native": "./scripts/run-validate.sh probe-factory --backend native",
    "validate:probe-factory:js": "./scripts/run-validate.sh probe-factory --backend js",
    "validate:probe-factory:all": "./scripts/run-validate.sh probe-factory --backend all",
    "validate:history": "./scripts/run-validate.sh history",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "type-check": "pnpm -r run type-check",
    "type-check:examples": "tsgo -p examples/tsconfig.json --noEmit",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "docs": "typedoc",
    "docs:md": "typedoc --plugin typedoc-plugin-markdown"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@napi-rs/cli": "^3.0.0",
    "@sittir/common": "workspace:*",
    "@sittir/python": "workspace:*",
    "@sittir/rust": "workspace:*",
    "@sittir/typescript": "workspace:*",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "@vitest/coverage-v8": "^4.1.6",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tree-sitter-cli": "^0.26.9",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-to-skills": "^0.6.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "web-tree-sitter": "^0.26.9"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}