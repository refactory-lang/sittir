{
	"lspServers": {
		"typescript": {
			"command": "typescript-language-server",
			"args": ["--stdio"],
			"fileExtensions": {
				".ts": "typescript",
				".tsx": "typescript",
				".mts": "typescript",
				".cts": "typescript",
				".js": "javascript",
				".jsx": "javascript",
				".mjs": "javascript",
				".cjs": "javascript"
			}
		},
		"rust": {
			"command": "rust-analyzer",
			"args": [],
			"fileExtensions": {
				".rs": "rust"
			}
		}
	}
}
