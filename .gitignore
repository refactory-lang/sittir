# `.sittir/` is the per-grammar generated-output staging area. The directory
# is ignored by default, but a few well-known generated artifacts are
# explicitly tracked via `git add -f`:
#   - grammar.js (tree-sitter grammar entry)
#   - package.json (codegen-emitted package manifest)
#   - tree-sitter.json (tree-sitter metadata)
#   - generated.manifest.json (codegen output fingerprint — see
#     packages/codegen/src/scripts/generated-manifest.ts)
# When adding new entries to this list, force-add them and document here.
packages/*/.sittir/


# Stray tree-sitter build artifacts (parser.wasm should be in .sittir/)
/tree-sitter-*.wasm
.worktrees/
scratch/

# Rust workspace (spec 012)
/target/
Cargo.lock

# napi-rs build outputs (spec 012 T036-T038): platform-specific .node
# binaries. Each developer rebuilds locally via
# `cd rust/crates/sittir-{lang} && napi build`.
rust/crates/sittir-*/*.node
.claude/worktrees/
tmp-scripts/
graphify-out/cache/**

# tsc build outputs accidentally landing alongside .ts source. These four
# packages have ZERO intentionally-tracked .js/.d.ts in src/ (verified
# 2026-05-15) — pure TS source. (packages/codegen and packages/validator
# DO track .js/.d.ts intentionally and are NOT covered by these rules.)
packages/common/src/**/*.js
packages/common/src/**/*.js.map
packages/common/src/**/*.d.ts
packages/common/src/**/*.d.ts.map
packages/core/src/**/*.js
packages/core/src/**/*.js.map
packages/core/src/**/*.d.ts
packages/core/src/**/*.d.ts.map
packages/types/src/**/*.js
packages/types/src/**/*.js.map
packages/types/src/**/*.d.ts
packages/types/src/**/*.d.ts.map
packages/tools/src/**/*.js
packages/tools/src/**/*.js.map
packages/tools/src/**/*.d.ts
packages/tools/src/**/*.d.ts.map
