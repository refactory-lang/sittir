# napi-rs build outputs (spec 012 T036–T038): platform-specific .node
# binaries + the auto-emitted index.js/index.d.ts shim. Each developer
# rebuilds locally via `cd rust/crates/sittir-{lang}-napi && napi build`.
rust/crates/sittir-*-napi/*.node
rust/crates/sittir-*-napi/index.js
rust/crates/sittir-*-napi/index.d.ts
.claude/worktrees/
