root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,mjs,cjs,json,json5,yaml,yml,md}]
indent_style = tab
indent_size = 4

[*.jinja]
# Generated per-rule templates (feature 011). Output preserves
# exactly whatever the codegen emitter produces — do not reformat.
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
