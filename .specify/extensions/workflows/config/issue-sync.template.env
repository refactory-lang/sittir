# Spec Kit Issue Sync Configuration
# Installed at: .specify/extensions/workflows/issue-sync.env
# Optional local override (recommended for repo-private settings):
#   .specify/extensions/workflows/issue-sync.local.env

# Optional explicit linked issue number. If empty, script tries auto-detection.
# SPECKIT_LINKED_ISSUE=123

# Optional explicit repository override in owner/repo format.
# SPECKIT_ISSUE_SYNC_REPO=owner/repo

# Create missing labels in the target repository when they do not exist.
SPECKIT_ISSUE_SYNC_BOOTSTRAP_LABELS=true

# Add a comment to the issue at every hook boundary.
SPECKIT_ISSUE_SYNC_COMMENT=false

# Per-event label mapping
SPECKIT_ISSUE_SYNC_LABEL_BEFORE_SPECIFY=speckit:before-specify
SPECKIT_ISSUE_SYNC_LABEL_AFTER_SPECIFY=speckit:after-specify
SPECKIT_ISSUE_SYNC_LABEL_BEFORE_PLAN=speckit:before-plan
SPECKIT_ISSUE_SYNC_LABEL_AFTER_PLAN=speckit:after-plan
SPECKIT_ISSUE_SYNC_LABEL_BEFORE_TASKS=speckit:before-tasks
SPECKIT_ISSUE_SYNC_LABEL_AFTER_TASKS=speckit:after-tasks
SPECKIT_ISSUE_SYNC_LABEL_BEFORE_IMPLEMENT=speckit:before-implement
SPECKIT_ISSUE_SYNC_LABEL_AFTER_IMPLEMENT=speckit:after-implement

# Optional per-event status text (used in comments when enabled)
SPECKIT_ISSUE_SYNC_STATUS_BEFORE_SPECIFY=discovering requirements
SPECKIT_ISSUE_SYNC_STATUS_AFTER_SPECIFY=spec ready
SPECKIT_ISSUE_SYNC_STATUS_BEFORE_PLAN=planning started
SPECKIT_ISSUE_SYNC_STATUS_AFTER_PLAN=plan approved
SPECKIT_ISSUE_SYNC_STATUS_BEFORE_TASKS=task breakdown started
SPECKIT_ISSUE_SYNC_STATUS_AFTER_TASKS=tasks ready
SPECKIT_ISSUE_SYNC_STATUS_BEFORE_IMPLEMENT=implementation started
SPECKIT_ISSUE_SYNC_STATUS_AFTER_IMPLEMENT=implementation completed
