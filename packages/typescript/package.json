{
	"name": "@sittir/typescript",
	"version": "0.1.0",
	"description": "Typed TypeScript IR builder — node kinds from tree-sitter-typescript grammar",
	"keywords": [
		"ast",
		"codegen",
		"ir",
		"tree-sitter",
		"typescript"
	],
	"homepage": "https://github.com/refactory-lang/sittir#readme",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/refactory-lang/sittir.git",
		"directory": "packages/typescript"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./utils": {
			"types": "./dist/utils.d.ts",
			"import": "./dist/utils.js"
		},
		"./tsx": {
			"types": "./dist/tsx/index.d.ts",
			"import": "./dist/tsx/index.js"
		}
	},
	"scripts": {
		"generate": "rm -f src/factories.ts src/from.ts src/ir.ts src/utils.ts src/types.ts src/consts.ts src/index.ts templates.yaml tests/nodes.test.ts && node --experimental-strip-types ../codegen/src/cli.ts --grammar typescript --all --output src/",
		"generate:tsx": "node ../codegen/dist/cli.js --grammar tsx --all --output src/tsx/ --tests-dir tests/tsx --tests-import-path '../../src/tsx/builder.js'",
		"regenerate": "pnpm generate && pnpm build && pnpm test",
		"build": "tsgo -p tsconfig.build.json",
		"clean": "rm -rf dist tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo",
		"dev": "tsgo -p tsconfig.build.json --watch",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"type-check": "tsgo --noEmit"
	},
	"dependencies": {
		"@sittir/core": "workspace:*",
		"@sittir/types": "workspace:*",
		"@sittir/common": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"tree-sitter-typescript": "^0.23.2",
		"type-fest": "^5.6.0"
	},
	"//native": "Native artifacts are grammar-local implementation details for @sittir/typescript, built from rust/crates/sittir-typescript."
}
