{
	"name": "@sittir/codegen",
	"version": "0.1.0",
	"description": "Generate typed IR builders from tree-sitter grammars",
	"keywords": [
		"ast",
		"code-generation",
		"codegen",
		"ir",
		"tree-sitter"
	],
	"homepage": "https://github.com/refactory-lang/sittir#readme",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/refactory-lang/sittir.git",
		"directory": "packages/codegen"
	},
	"bin": {
		"sittir": "./src/cli.ts"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "pnpm run clean && tsgo -p tsconfig.build.json",
		"clean": "rm -rf dist tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo",
		"dev": "tsgo -p tsconfig.build.json --watch",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"type-check": "tsgo --noEmit",
		"generate:rust": "tsx ./src/cli.ts --grammar rust -a --output packages/rust/src",
		"generate:ts": "tsx ./src/cli.ts --grammar typescript -a --output packages/typescript/src",
		"generate:python": "tsx ./src/cli.ts --grammar python -a --output packages/python/src",
		"generate:all": "pnpm run generate:rust && pnpm run generate:ts && pnpm run generate:python"
	},
	"dependencies": {
		"@sittir/core": "workspace:*",
		"@sittir/types": "workspace:*",
		"@sittir/common": "workspace:*"
	},
	"devDependencies": {
		"@ast-grep/wasm": "^0.42.1",
		"@sittir/typescript": "workspace:*",
		"@types/node": "^25.6.0",
		"esbuild": "^0.28.0",
		"tree-sitter-c": "^0.24.1",
		"tree-sitter-go": "^0.25.0",
		"tree-sitter-rust": "^0.24.0",
		"tree-sitter-typescript": "^0.23.2",
		"type-fest": "^5.6.0",
		"web-tree-sitter": "^0.26.8"
	}
}
