{
	"name": "@sittir/types",
	"version": "0.1.0",
	"description": "Language-agnostic type projection from tree-sitter grammars to typed IR builders",
	"keywords": [
		"codegen",
		"ir",
		"tree-sitter",
		"types",
		"typescript"
	],
	"homepage": "https://github.com/refactory-lang/sittir#readme",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/refactory-lang/sittir.git",
		"directory": "packages/types"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"clean": "rm -rf dist tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo",
		"dev": "tsc -p tsconfig.build.json --watch",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"type-fest": "^5.6.0"
	}
}
