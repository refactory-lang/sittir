{
  "name": "@sittir/core",
  "version": "0.1.0",
  "description": "Grammar-driven render engine, validation, CST, and Edit creation for sittir",
  "license": "MIT",
  "homepage": "https://github.com/refactory-lang/sittir#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/refactory-lang/sittir.git",
    "directory": "packages/core"
  },
  "keywords": [
    "tree-sitter",
    "ir",
    "render",
    "cst",
    "ast-grep"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "type-check": "tsgo --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sittir/types": "workspace:*"
  },
  "devDependencies": {
    "@ast-grep/napi": "^0.42.0"
  }
}
