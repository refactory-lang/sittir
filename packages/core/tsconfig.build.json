{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"tsBuildInfoFile": "./tsconfig.build.tsbuildinfo",
		"paths": {}
	},
	"references": [{ "path": "../types/tsconfig.build.json" }, { "path": "../common/tsconfig.build.json" }],
	"include": [
		"src/index.ts",
		"src/engine-boundary.ts",
		"src/engine.ts",
		"src/loader.ts",
		"src/render.ts",
		"src/types.ts",
		"src/validate.ts",
		"src/templates/**/*.ts"
	],
	"exclude": ["node_modules", "dist"]
}
