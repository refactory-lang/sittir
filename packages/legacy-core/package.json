{
	"name": "@sittir/legacy-core",
	"version": "0.1.0",
	"description": "Deprecated JS/Nunjucks backend — diagnostic and validator tooling only, not a production render engine",
	"keywords": [
		"ast-grep",
		"cst",
		"ir",
		"render",
		"tree-sitter"
	],
	"homepage": "https://github.com/refactory-lang/sittir#readme",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/refactory-lang/sittir.git",
		"directory": "packages/legacy-core"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./engine": {
			"types": "./dist/engine-boundary.d.ts",
			"import": "./dist/engine-boundary.js",
			"default": "./dist/engine-boundary.js"
		}
	},
	"scripts": {
		"build": "tsgo -p tsconfig.build.json",
		"clean": "rm -rf dist tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo",
		"dev": "tsgo -p tsconfig.build.json --watch",
		"type-check": "tsgo --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@sittir/types": "workspace:*",
		"nunjucks": "^3.2.4",
		"yaml": "^2.8.3",
		"@sittir/common": "workspace:*"
	},
	"devDependencies": {
		"@ast-grep/napi": "^0.42.1",
		"@types/node": "^25.6.0",
		"@types/nunjucks": "^3.2.6"
	}
}
