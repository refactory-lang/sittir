{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FormatCorpusManifest",
  "description": "Authoritative acceptance fixture set for feature 017 (format-inference). See FR-012.",
  "type": "object",
  "required": ["fixtures"],
  "properties": {
    "fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "grammar", "category", "seedSource", "expectedBackendCoverage", "fixturePath"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique kebab-case identifier for the fixture"
          },
          "grammar": {
            "type": "string",
            "enum": ["rust", "typescript", "python"],
            "description": "Grammar package under test"
          },
          "category": {
            "type": "string",
            "enum": ["whitespace", "separators", "optional-tokens", "literals", "trivia"],
            "description": "Format dimension under test"
          },
          "seedSource": {
            "type": "string",
            "enum": ["016-deferred", "017-measured"],
            "description": "Origin of this fixture"
          },
          "expectedBackendCoverage": {
            "type": "string",
            "enum": ["typescript", "both"],
            "description": "Which backends must pass this fixture (both = TS + native)"
          },
          "fixturePath": {
            "type": "string",
            "description": "Repo-relative path to the source fixture file"
          },
          "notes": {
            "type": "string",
            "description": "Optional free-text notes about the fixture"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
